# Скопируйте в .env и заполните значения. Файл .env в репозиторий не коммитится.

TELEGRAM_TOKEN=
# Путь к корню хранилища Obsidian (или другой папке), куда пишутся .md
VAULT_PATH=

# Календарь для имён файлов и заголовков: время из Telegram (UTC) переводится в этот пояс.
# Проще всего — смещение: UTC+3, UTC+5, UTC-5 (можно UTC+03:30). Либо IANA: Europe/Moscow.
# На VPS укажите то же значение, что и на ПК.
USER_TIMEZONE=UTC+3

# Необязательно: через запятую/пробел/точку с запятой — список Telegram user id, которым разрешено писать боту.
# Узнать свой id: @userinfobot и т.п. Пусто = принимать от всех.
# ALLOWED_USER_IDS=123456789

# Необязательно: прокси для запросов к Telegram Bot API (тот же тип, что в Telegram Desktop).
# Примеры:
#   socks5://127.0.0.1:1080
#   socks5://user:password@host:1080
#   http://127.0.0.1:8080
PROXY_URL=

# --- Режим VPS → ПК (bot_server.py на сервере, receiver.py на ПК) ---
# Одинаковый RECEIVER_SECRET на VPS и ПК, не короче 24 символов (см. docs/RECEIVER_SECURITY.md).
# RECEIVER_URL=https://....   # лучше HTTPS туннеля (ngrok / cloudflared)
# RECEIVER_SECRET=
# На ПК для receiver.py:
# RECEIVER_HOST=127.0.0.1
# RECEIVER_PORT=8080
# RECEIVER_MAX_SKEW_SEC=600
# RECEIVER_NONCE_TTL_SEC=600
# Только локальные тесты: RECEIVER_INSECURE_DEV=1
# На VPS для bot_server.py (только если сам VPS не достучится до api.telegram.org):
# PROXY_URL=socks5://user:pass@host:1080

# Обратный SSH с Windows без ключа: пароль VPS (не коммитить). Нужен PuTTY — plink.exe в PATH.
# DEPLOY_SSH_PASSWORD=
