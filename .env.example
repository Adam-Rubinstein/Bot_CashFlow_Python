# Скопируйте в .env и заполните значения. Файл .env в репозиторий не коммитится.

TELEGRAM_TOKEN=
# Путь к корню хранилища Obsidian (или другой папке), куда пишутся .md
VAULT_PATH=

# Необязательно: прокси для запросов к Telegram Bot API (тот же тип, что в Telegram Desktop).
# Примеры:
#   socks5://127.0.0.1:1080
#   socks5://user:password@host:1080
#   http://127.0.0.1:8080
PROXY_URL=
